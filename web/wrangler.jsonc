{
  "$schema": "node_modules/wrangler/config-schema.json",
  "main": ".open-next/worker.js",
  "name": "promptbridge007",
  "compatibility_date": "2024-12-30",
  "compatibility_flags": [
    // Enable Node.js API
    "nodejs_compat"
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "promptbridge007",
      "database_id": "c962d07b-ddd9-430d-85fa-0bb6d5322ab2"
    }
  ]
}
